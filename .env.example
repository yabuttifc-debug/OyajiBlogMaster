# Anthropic API Key (https://console.anthropic.com/ で取得)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 認証情報を暗号化するマスターパスワード（自分で決める任意の文字列）
MASTER_PASSWORD=your_master_password_here

# Discord Webhook URL（サーバ設定 → 連携サービス → ウェブフック で取得）
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxxxxxxx/xxxxxxxxxx
